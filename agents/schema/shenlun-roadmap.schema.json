{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gongkao-agent.local/schema/shenlun-roadmap.schema.json",
  "title": "申论系统学习知识库",
  "type": "object",
  "required": ["title", "description", "stages", "questionTypes", "references"],
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "type": { "const": "study-roadmap" },
        "subject": { "const": "shenlun" },
        "version": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date" },
        "contentKind": { "type": "string" }
      }
    },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "basisNote": { "type": "string" },
    "examGuide": {
      "type": "object",
      "required": ["syllabusTitle", "syllabusDate", "syllabusUrl", "durationMinutes", "score", "paperTypes"],
      "properties": {
        "syllabusTitle": { "type": "string" },
        "syllabusDate": { "type": "string", "format": "date" },
        "syllabusUrl": { "type": "string", "format": "uri" },
        "durationMinutes": { "type": "integer" },
        "score": { "type": "integer" },
        "paperTypes": { "type": "array", "minItems": 1 }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "goal", "tasks"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "goal": { "type": "string" },
          "duration": { "type": "string" },
          "tasks": { "type": "array", "items": { "type": "string" } },
          "knowledgePoints": { "type": "array", "items": { "type": "string" } },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "milestone": { "type": "string" }
        }
      }
    },
    "questionTypes": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "title", "coreGoal", "answerFramework", "pointMethods", "pitfalls", "drills"]
      }
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "publisher", "kind", "url", "note", "accessedAt"]
      }
    }
  }
}
