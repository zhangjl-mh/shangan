{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gongkao-agent.local/schema/eligible-jobs.schema.json",
  "title": "当前尚未考试且符合用户画像或需立即核验的岗位",
  "type": "object",
  "required": ["generatedAt", "positions"],
  "properties": {
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceScope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "categoryOrder": {
      "type": "array",
      "items": { "type": "string" }
    },
    "regionOrder": {
      "type": "array",
      "items": { "type": "string" }
    },
    "referencePolicy": {
      "type": "string"
    },
    "regionalScanNote": {
      "type": "string"
    },
    "screeningNote": {
      "type": "string"
    },
    "scanWorkflow": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "description"],
        "properties": {
          "step": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "searchedSources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url", "checkedAt", "result"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "checkedAt": { "type": "string", "format": "date-time" },
          "result": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "positions": {
      "type": "array",
      "items": { "$ref": "#/$defs/position" }
    }
  },
  "$defs": {
    "position": {
      "type": "object",
      "required": [
        "id",
        "title",
        "organization",
        "category",
        "region",
        "status",
        "sourceName",
        "sourceUrl",
        "capturedAt"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "organization": { "type": "string" },
        "category": {
          "enum": ["公务员", "编制", "国企"],
          "description": "页面顶层分类只保留公务员、编制和国企"
        },
        "recruitmentClass": {
          "enum": ["国考", "省考", "编制", "国企"],
          "description": "岗位页第一层展示分组。公务员需细分为国考和省考。"
        },
        "department": { "type": "string" },
        "positionCode": { "type": "string" },
        "recruitmentType": { "type": "string" },
        "region": { "type": "string" },
        "regionGroup": {
          "enum": ["北京", "雄安", "天津", "石家庄", "其他"],
          "description": "岗位页第二层展示分组。"
        },
        "district": { "type": "string" },
        "recruitCount": { "type": "integer", "minimum": 1 },
        "responsibilities": { "type": "string" },
        "educationRequirement": { "type": "string" },
        "majorRequirement": { "type": "string" },
        "freshGraduateRequirement": { "type": "string" },
        "matchScore": { "type": "integer", "minimum": 0, "maximum": 100 },
        "matchLevel": { "type": "string" },
        "riskLevel": { "type": "string" },
        "recommendation": { "type": "string" },
        "matchReasons": { "type": "array", "items": { "type": "string" } },
        "riskReminders": { "type": "array", "items": { "type": "string" } },
        "studyAdvice": { "type": "array", "items": { "type": "string" } },
        "benefits": { "type": "array", "items": { "type": "string" } },
        "housingReference": { "type": "string" },
        "householdReference": { "type": "string" },
        "officialOnlyNotice": { "type": "string" },
        "eligibilityBasis": {
          "type": "array",
          "items": { "type": "string" }
        },
        "advantages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "applicationNotes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "historicalReferences": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["year", "sourceName", "sourceUrl"],
            "properties": {
              "year": { "type": "string" },
              "finalEntryScore": { "type": "string" },
              "applicationRatio": { "type": "string" },
              "recruitmentCount": { "type": "string" },
              "note": { "type": "string" },
              "sourceName": { "type": "string" },
              "sourceUrl": { "type": "string", "format": "uri" }
            },
            "additionalProperties": false
          }
        },
        "compensationReference": {
          "type": "object",
          "required": ["text", "disclaimer"],
          "properties": {
            "text": { "type": "string" },
            "source": { "type": "string" },
            "sourceUrl": { "type": "string", "format": "uri" },
            "disclaimer": {
              "type": "string",
              "description": "必须说明此信息非当前岗位官方薪资承诺"
            }
          },
          "additionalProperties": false
        },
        "announcementDate": { "type": "string", "format": "date" },
        "registrationStartDate": { "type": "string", "format": "date" },
        "registrationEndDate": { "type": "string", "format": "date" },
        "registrationEndAt": { "type": "string", "format": "date-time" },
        "qualificationReviewEndAt": { "type": "string", "format": "date-time" },
        "paymentEndAt": { "type": "string", "format": "date-time" },
        "examDate": { "type": "string", "format": "date" },
        "status": {
          "enum": ["即将报名", "报名中", "待考试"]
        },
        "sourceName": { "type": "string" },
        "sourceUrl": { "type": "string", "format": "uri" },
        "capturedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
